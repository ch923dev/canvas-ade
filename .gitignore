# deps
node_modules/

# build output
out/
dist/
release/
# electron-builder alternate outputs + pruned electronDist copies (see eslint ignore rationale).
release-*/
spike-*/

# logs / os
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# env / secrets
.env
.env.*
*.pem
*.p12

# editor
.vscode/*
!.vscode/extensions.json
.idea/

# electron-builder cache
.cache/

# agent worktrees (harness-managed git worktrees for parallel work)
.claude/worktrees/
# manual parallel-session worktrees (created by .claude/tools/new-worktree.ps1) - nested in-repo, never tracked
.worktrees/
# harness runtime artifacts
.claude/scheduled_tasks.lock
.claude/skills/
# harness scratch (screenshots, audit parses, PR drafts) — never tracked
.claude/tmp/
# throwaway design-artifact mocks (the "design artifact before code" policy — HTML/PNG, never tracked)
.claude/mocks/
# machine-specific local settings (bridgespace hooks w/ absolute user paths) — never tracked
.claude/settings.local.json
# parallel-session coordination: track the tooling (hook + ps1), ignore the live shared state
.claude/coordination/ACTIVE-WORK.md
.claude/coordination/edit-log.jsonl
.claude/coordination/integration-tip.json
.claude/coordination/merge-signal.jsonl
.claude/coordination/fetch-stamps/
.claude/coordination/archive/
# agent tooling — workflow scripts + skills lockfile (NOT project source)
.agents/
skills-lock.json

# local config/file backups (e.g. CLAUDE.md.bak-YYYYMMDD)
*.bak-*

# stray project-persistence artifacts written when the app runs against the repo root
# (a real project's canvas.json lives in the user-chosen folder, never in this repo)
canvas.json
canvas.json.bak

# Expanse-generated project-data dir (ADR 0009): opening this repo in the app it builds
# writes canvas.json / assets / memory / tmp scratch here. Never tracked.
.canvas/

# MCP-provisioner output (agent-orch per-CLI provisioners): when the app connects a
# Terminal-board CLI (Claude Code -> .mcp.json, opencode -> opencode.json, ...) to its own
# canvas-ade MCP server, it writes a client config here carrying an EPHEMERAL localhost port
# + a per-run bearer TOKEN (a secret). Runtime artifact — never tracked.
.mcp.json
opencode.json

# Playwright (T4 e2e)
/test-results/
/playwright-report/
/e2e/.cache/
# repro scratchpad (copy of _repro.e2e.ts.template) — never committed; promote to a real spec
/e2e/_repro.e2e.ts
# Playwright MCP scratch (browser snapshots / console logs from the MCP server) — never tracked
/.playwright-mcp/

# Local Claude Code design-hook cache (impeccable plugin) — session tooling, never source.
.impeccable/

# STT eval harness (scripts/stt-eval) — the recorded corpus is the maintainer's OWN VOICE
# and the results carry raw transcripts, so neither is tracked by default. `prompts.json`
# (the read-aloud script) IS tracked, so anyone can re-record the same corpus locally.
# Opt in deliberately with `git add -f` if a shared reference corpus is ever wanted.
/scripts/stt-eval/corpus/*.wav
/scripts/stt-eval/corpus/manifest.json
/scripts/stt-eval/results/
