# deps
node_modules/

# build output
out/
dist/
release/

# logs / os
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# env / secrets
.env
.env.*
*.pem
*.p12

# editor
.vscode/*
!.vscode/extensions.json
.idea/

# electron-builder cache
.cache/

# agent worktrees (harness-managed git worktrees for parallel work)
.claude/worktrees/
# harness runtime artifacts
.claude/scheduled_tasks.lock
.claude/skills/
# harness scratch (screenshots, audit parses, PR drafts) — never tracked
.claude/tmp/
# parallel-session coordination: track the tooling (hook + ps1), ignore the live shared state
.claude/coordination/ACTIVE-WORK.md
.claude/coordination/edit-log.jsonl
.claude/coordination/archive/
# agent tooling — workflow scripts + skills lockfile (NOT project source)
.agents/
skills-lock.json

# local config/file backups (e.g. CLAUDE.md.bak-YYYYMMDD)
*.bak-*

# stray project-persistence artifacts written when the app runs against the repo root
# (a real project's canvas.json lives in the user-chosen folder, never in this repo)
canvas.json
canvas.json.bak

# Playwright (T4 e2e)
/test-results/
/playwright-report/
/e2e/.cache/
