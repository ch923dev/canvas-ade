# Electron + native modules (node-pty) build cleanly with a flat, npm-like layout.
# pnpm's default symlinked store confuses @electron/rebuild + electron-builder.
node-linker=hoisted
strict-peer-dependencies=false

# @ch923dev/canvas-ade-mcp is published to GitHub Packages (private). Route only
# that scope there; everything else stays on the default npmjs registry. Auth via
# NODE_AUTH_TOKEN (CI: GITHUB_TOKEN with packages:read after the repo is granted
# read access to the package; local dev: a read:packages token).
@ch923dev:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
