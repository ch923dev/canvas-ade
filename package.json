{
  "name": "canvas-ade",
  "version": "0.0.0",
  "description": "An infinite, zoomable canvas for AI-assisted development.",
  "author": "cdeasis923",
  "license": "UNLICENSED",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:preload": "tsc --noEmit -p tsconfig.preload.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:preload && pnpm typecheck:web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit-*",
    "test:integration": "vitest run --project integration-*",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "pretest:e2e": "electron-vite build",
    "test:e2e:linux": "docker build -f Dockerfile.e2e -t canvas-e2e-linux . && docker run --rm canvas-e2e-linux && docker builder prune -f --filter until=168h",
    "test:e2e:matrix": "pnpm test:e2e && pnpm test:e2e:linux",
    "rebuild": "electron-rebuild -f -w node-pty",
    "mcp:build": "pnpm --dir ../canvas-ade-mcp build",
    "mcp:link": "pnpm link ../canvas-ade-mcp",
    "mcp:dev": "pnpm mcp:build && pnpm mcp:link",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks')}catch(e){process.stderr.write('[prepare] WARNING: git config core.hooksPath .githooks failed (' + e.message + '). Pre-commit and pre-push hooks may not be active.\\n')}\"",
    "pack:dir": "electron-vite build && electron-builder --dir",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@expanse-ade/mcp": "^0.9.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "1.2.0-beta.13",
    "simple-git": "^3.27.0",
    "write-file-atomic": "^8.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/write-file-atomic": "^4.0.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.3.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "geist": "^1.7.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "zustand": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ],
    "overrides": {
      "tar": ">=7.5.8",
      "esbuild": ">=0.28.1",
      "postcss": ">=8.5.10"
    }
  }
}
