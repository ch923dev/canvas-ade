{
  "name": "canvas-ade",
  "version": "0.22.6",
  "description": "An infinite, zoomable canvas for AI-assisted development.",
  "author": "cdeasis923",
  "license": "UNLICENSED",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:preload": "tsc --noEmit -p tsconfig.preload.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:preload && pnpm typecheck:web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit-*",
    "test:integration": "vitest run --project integration-*",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "pretest:e2e": "set CANVAS_E2E=1&& electron-vite build",
    "pretest:e2e:smoke": "set CANVAS_E2E=1&& electron-vite build",
    "test:e2e:smoke": "playwright test --grep @core",
    "test:e2e:linux": "docker build -f Dockerfile.e2e -t canvas-e2e-linux . && docker run --rm canvas-e2e-linux && docker builder prune -f --filter until=168h",
    "test:e2e:matrix": "pnpm test:e2e && pnpm test:e2e:linux",
    "rebuild": "electron-rebuild -f -w node-pty",
    "mcp:build": "pnpm --dir ../canvas-ade-mcp build",
    "mcp:link": "pnpm link ../canvas-ade-mcp",
    "mcp:dev": "pnpm mcp:build && pnpm mcp:link",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks')}catch(e){process.stderr.write('[prepare] WARNING: git config core.hooksPath .githooks failed (' + e.message + '). Pre-commit and pre-push hooks may not be active.\\n')}\"",
    "pack:dir": "electron-vite build && electron-builder --dir",
    "feed:gen": "node scripts/gen-updates-json.mjs",
    "release:win": "node scripts/release.mjs --win",
    "release:mac": "node scripts/release.mjs --mac",
    "release:linux": "node scripts/release.mjs --linux",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "//packaging-pins": "ajv + signal-exit are NOT imported by app code — they pin their PROD transitive versions (ajv@8 via @expanse-ade/mcp's MCP SDK; signal-exit@4 via write-file-atomic@8) into the node_modules ROOT. electron-builder only collects depth-1 deps; pnpm otherwise nests these under their consumers while the dev-hoisted ajv@6/signal-exit@3 take root, so the PACKAGED app crashes (MODULE_NOT_FOUND on signal-exit / onExit-not-a-function on save). DO NOT remove as 'unused'. See docs/contributing/releasing.md › Packaging dependency pins.",
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@expanse-ade/mcp": "0.20.1",
    "@uiw/codemirror-extensions-langs": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "ajv": "^8.20.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "1.2.0-beta.13",
    "sherpa-onnx-node": "^1.13.3",
    "signal-exit": "^4.1.0",
    "simple-git": "^3.27.0",
    "write-file-atomic": "^8.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/write-file-atomic": "^4.0.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "0.14.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.11.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.5",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "geist": "^1.7.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react": "^19.2.7",
    "react-arborist": "^3.10.5",
    "react-dom": "^19.2.7",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "zustand": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ],
    "overrides": {
      "tar": ">=7.5.8",
      "esbuild": ">=0.28.1",
      "postcss": ">=8.5.10",
      "form-data": ">=4.0.6",
      "hono": ">=4.12.25",
      "undici@>=7.23.0 <7.28.0": ">=7.28.0 <8",
      "undici@>=6.0.0 <6.27.0": ">=6.27.0 <7",
      "@codemirror/state": "6.7.0"
    }
  }
}
