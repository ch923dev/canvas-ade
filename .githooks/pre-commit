#!/bin/sh
# Pre-commit CHEAP gate (fast static checks only). The slow e2e matrix moved to
# `.githooks/pre-push` (2026-06-06) so local commits stay fast — e2e now runs only
# when you push to origin. Rationale: `git commit` carries no push-intent signal,
# so "only gate when going to origin" is a PRE-PUSH concern, not pre-commit.
# This hook keeps the fast trio (typecheck · lint · format:check) for instant local
# feedback. Bypass a WIP commit with:  git commit --no-verify
# Enabled by `core.hooksPath=.githooks` (set by the package.json `prepare` script).
set -e

if ! command -v pnpm >/dev/null 2>&1; then
  echo "[pre-commit] ERROR: pnpm not on PATH. Run 'corepack enable' first."
  exit 1
fi

# Docs-only commits can't break types/lint — skip typecheck (the slow leg, tsc ×3)
# but still run format:check so stray .md prettier drift is caught. The filter
# passes only when EVERY staged path is under docs/ or ends in .md.
STAGED="$(git diff --cached --name-only --diff-filter=ACMR)"
if [ -n "$STAGED" ] && ! printf '%s\n' "$STAGED" | grep -qvE '(^docs/|\.md$)'; then
  echo "[pre-commit] docs-only commit — format:check only."
  pnpm format:check
  exit 0
fi

echo "[pre-commit] cheap gate: typecheck · lint · format:check (~seconds)."
pnpm typecheck
pnpm lint
pnpm format:check
