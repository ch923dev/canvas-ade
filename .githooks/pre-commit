#!/bin/sh
# Pre-commit e2e gate. e2e (Playwright _electron) was moved OFF GitHub Actions
# (Actions billing) and runs HERE instead: the full Windows-native + Linux-Docker
# matrix via `pnpm test:e2e:matrix`. Enabled by `core.hooksPath=.githooks` (set by
# the package.json `prepare` script on install). Bypass a WIP commit with:
#     git commit --no-verify
set -e

echo "[pre-commit] e2e matrix (Windows native + Linux Docker) — this takes ~2-3 min."

if ! command -v pnpm >/dev/null 2>&1; then
  echo "[pre-commit] ERROR: pnpm not on PATH. Run 'corepack enable' first."
  exit 1
fi

# The Linux leg runs in Docker — fail early with a clear message if it is not up.
if ! docker info >/dev/null 2>&1; then
  echo "[pre-commit] ERROR: Docker daemon not running — the Linux e2e leg needs it."
  echo "             Start Docker Desktop, or bypass this commit with: git commit --no-verify"
  exit 1
fi

# E2E_PRECOMMIT=1 turns on Playwright retries:2 (see playwright.config.ts) so the
# documented browser-trio env flake doesn't false-block a commit.
E2E_PRECOMMIT=1 pnpm test:e2e:matrix
