#!/bin/sh
# Pre-push e2e gate (2026-06-06). The full Windows-native + Linux-Docker e2e matrix
# (Playwright `_electron`, `pnpm test:e2e:matrix`) runs HERE — only when pushing to
# origin — instead of on every `git commit`. Why here and not pre-commit: `git commit`
# carries no push-intent signal, so "gate only when work reaches origin" is inherently
# a push concern. Local commits now skip e2e entirely; this fires once per push.
# e2e was moved off GitHub Actions earlier (Actions billing) — this is the real gate.
# Bypass a WIP push with:  git push --no-verify
# Enabled by `core.hooksPath=.githooks` (set by the package.json `prepare` script).
#
# git passes the remote NAME as $1 and URL as $2; the refs being pushed arrive on
# stdin, one line per ref:  <local ref> <local sha> <remote ref> <remote sha>
set -e

remote_name="$1"
# Only gate pushes to origin — pushing to a fork/scratch remote shouldn't pay e2e.
[ "$remote_name" = "origin" ] || { echo "[pre-push] remote '$remote_name' != origin — skipping e2e."; exit 0; }

z40="0000000000000000000000000000000000000000"
changed=""
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue                 # branch delete — nothing to test
  if [ "$remote_sha" = "$z40" ]; then
    # New branch on remote: diff from the common ancestor with origin/main so we
    # classify ALL commits on the feature branch — not against the working tree
    # (a bare single sha compares to the working tree, which is always empty on a
    # clean checkout and gives wrong results on a dirty one; BUG-018).
    base="$(git merge-base origin/main "$local_sha" 2>/dev/null)" || base=""
    if [ -z "$base" ]; then
      # No merge-base (unrelated/shallow history): take the OLDEST commit not on any
      # origin ref and diff from its PARENT — `F..tip` excludes F's own changes, and a
      # single-commit branch would make the range empty and silently skip the matrix.
      # A root-commit parent makes git diff fail → the BUG-068 guard forces force-full.
      first_new="$(git rev-list "$local_sha" --not --remotes=origin 2>/dev/null | tail -1)" || first_new=""
      if [ -n "$first_new" ]; then base="${first_new}^"; fi
    fi
    if [ -z "$base" ]; then
      # Cannot determine a safe base — run the full matrix rather than skip.
      echo "[pre-push] WARNING: could not find merge-base for new branch '$local_ref' — running full e2e matrix."
      changed="${changed}force-full
"
      continue
    fi
    range="$base..$local_sha"
  else
    range="$remote_sha..$local_sha"                     # only the commits being pushed
  fi
  # BUG-068: guard against git diff exit-non-zero (object missing locally after
  # a force-push from another machine); fall back to running the full matrix so
  # the hook never silently succeeds due to set -e swallowing 2>/dev/null errors.
  diff_out="$(git diff --name-only --diff-filter=ACMRD "$range" 2>/dev/null)" || {
    echo "[pre-push] WARNING: git diff failed for range '$range' (remote tip may not be local) — running full e2e matrix."
    changed="${changed}force-full
"
    continue
  }
  changed="$changed$diff_out
"
done

# Drop blank lines (the per-ref accumulation above leaves a trailing newline; a
# blank line matches neither docs pattern, so it would defeat the docs-only skip)
# and dedupe across refs.
changed="$(printf '%s\n' "$changed" | grep -v '^[[:space:]]*$' | sort -u)"

# Nothing to push (e.g. up-to-date / delete-only) → no e2e.
if [ -z "$changed" ]; then
  echo "[pre-push] no new commits to test — skipping e2e."
  exit 0
fi

# Docs-only push → skip the matrix (no runtime/build/test surface touched).
if ! printf '%s\n' "$changed" | grep -qvE '(^docs/|\.md$)'; then
  echo "[pre-push] docs-only push — skipping e2e matrix."
  exit 0
fi

echo "[pre-push] REMINDER: run the manual checks in docs/testing/MANUAL-CHECKS.md for the areas you touched -- it catches what e2e/unit do not."
echo "[pre-push] e2e matrix (Windows native + Linux Docker) — this takes ~2-3 min."

if ! command -v pnpm >/dev/null 2>&1; then
  echo "[pre-push] ERROR: pnpm not on PATH. Run 'corepack enable' first."
  exit 1
fi

# The Linux leg runs in Docker — fail early with a clear message if it is not up.
if ! docker info >/dev/null 2>&1; then
  echo "[pre-push] ERROR: Docker daemon not running — the Linux e2e leg needs it."
  echo "           Start Docker Desktop, or bypass this push with: git push --no-verify"
  exit 1
fi

# E2E_PRECOMMIT=1 turns on Playwright retries:2 (see playwright.config.ts) so the
# documented browser-trio env flake doesn't false-block a push.
E2E_PRECOMMIT=1 pnpm test:e2e:matrix
