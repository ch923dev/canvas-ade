# Supabase Edge Function secrets for Expanse.
# Load into the remote project with:  supabase secrets set --env-file supabase/.env
# (copy this file to supabase/.env first and fill in the real value)
#
# The public WorkOS Client ID — used to build the JWKS URL the `license` function verifies tokens
# against. This is NOT a secret (it's a public client identifier), but env files stay un-committed.
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxx
